{
  "name": "@loot-game/server",
  "main": "src/index.ts",
  "packageManager": "bun@1.2.23",
  "type": "module",
  "scripts": {
    "dev": "doppler run --mount .env -- bunx wrangler dev --port 3000",
    "dev:prd": "doppler run -c prd --mount .env -- bunx wrangler dev --port 3000",
    "types": "doppler run --mount .env -- bunx wrangler types",
    "start": "bun run src/index.ts",
    "deploy": "doppler run -c prd --mount .env -- bunx wrangler secret bulk .env && bunx wrangler deploy",
    "db:push": "doppler run --mount .env -- bunx drizzle-kit push",
    "db:push:prod": "doppler run -c prd --mount .env -- bunx drizzle-kit push",
    "db:studio": "doppler run --mount .env -- bunx drizzle-kit studio",
    "db:studio:prod": "doppler run -c prd --mount .env -- bunx drizzle-kit studio"
  },
  "dependencies": {
    "@clerk/backend": "^2.29.4",
    "@faker-js/faker": "^10.2.0",
    "@hono/clerk-auth": "^3.1.0",
    "@hono/trpc-server": "^0.4.2",
    "@loot-game/game": "workspace:*",
    "@neondatabase/serverless": "^1.0.2",
    "@sentry/cloudflare": "^10.36.0",
    "@trpc/server": "^11.8.1",
    "@types/seedrandom": "^3.0.8",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.11.5",
    "immer": "^10.2.0",
    "nanoid": "^5.1.6",
    "postgres": "^3.4.8",
    "seedrandom": "^3.0.5",
    "superjson": "^2.2.6",
    "wrangler": "^4.60.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "drizzle-kit": "^0.31.8"
  }
}
