{
  "name": "@loot-game/stack",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '@loot-game/*' dev",
    "dev:client": "bun run --filter @loot-game/client dev",
    "dev:server": "bun run --filter @loot-game/server dev",
    "db:local": "bun run --filter @loot-game/server db:local",
    "db:push": "bun run --filter @loot-game/server db:push",
    "clean": "rm -rf node_modules packages/client/node_modules packages/server/node_modules bun.lock packages/client/bun.lock packages/server/bun.lock"
  },
  "dependencies": {}
}
